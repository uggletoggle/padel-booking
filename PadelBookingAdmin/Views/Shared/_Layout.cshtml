<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PadelAdmin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>🎾 PadelAdmin</h2>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a href="/" class="nav-link">Dashboard</a></li>
                    <li><a href="/Clubs" class="nav-link">Clubs</a></li>
                    <li><a href="/Users" class="nav-link">Users</a></li>
                    <li><a href="/Home/Profile" class="nav-link">My Profile</a></li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="user-name">@User.Identity.Name</span>
                    <a href="/Home/Logout" class="btn btn-logout">Logout</a>
                }
                else
                {
                    <a href="/Home/Login" class="btn btn-login">Login</a>
                }
            </div>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div class="topbar-title">
                    <h1>@ViewData["Title"]</h1>
                </div>
            </header>
            
            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
