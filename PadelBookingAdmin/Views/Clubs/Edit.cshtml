@model PadelBookingAdmin.Models.Clubs.UpdateClubRequest

@{
    ViewData["Title"] = "Edit Club";
}

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2 class="card-title">Edit Club</h2>
    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Update the details for this club.</p>

    <form asp-action="Edit" method="post" asp-route-id="@ViewBag.Id">
        <div asp-validation-summary="All" style="color: #ef4444; margin-bottom: 1rem;"></div>

        <div class="form-group">
            <label class="form-label" asp-for="Name">Club Name</label>
            <input class="form-control" asp-for="Name" required />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Address">Address</label>
            <input class="form-control" asp-for="Address" required />
        </div>

        <div class="form-group" style="display: flex; gap: 1rem;">
            <div style="flex: 1;">
                <label class="form-label" asp-for="OpenTime">Open Time</label>
                <input class="form-control" type="time" asp-for="OpenTime" required />
            </div>
            <div style="flex: 1;">
                <label class="form-label" asp-for="CloseTime">Close Time</label>
                <input class="form-control" type="time" asp-for="CloseTime" required />
            </div>
        </div>

        <div class="form-group">
            <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" asp-for="IsActive" style="width: 1.25rem; height: 1.25rem; accent-color: var(--primary);" />
                <span class="form-label" style="margin: 0;">Is Active</span>
            </label>
        </div>

        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <a asp-action="Index" class="btn" style="flex: 1; background-color: var(--border-color); color: var(--text-color);">Cancel</a>
            <button type="submit" class="btn btn-primary" style="flex: 2;">Save Changes</button>
        </div>
    </form>
</div>
