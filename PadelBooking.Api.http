@Api_HostAddress = http://localhost:5175

###
# CLUBS
###

# 1. Create a new Club
# @name createClub
POST {{Api_HostAddress}}/api/clubs
Content-Type: application/json

{
  "name": "Padel Club Central",
  "address": "Av. Libertador 1234",
  "openTime": "08:00:00",
  "closeTime": "23:00:00"
}

###

# 2. Get all Clubs
GET {{Api_HostAddress}}/api/clubs

###

@ClubId = {{createClub.response.body.id}}

# 3. Get a single Club
GET {{Api_HostAddress}}/api/clubs/{{ClubId}}

###

# 4. Update a Club
PUT {{Api_HostAddress}}/api/clubs/{{ClubId}}
Content-Type: application/json

{
  "name": "Padel Club Central Updated",
  "address": "Av. Libertador 1234",
  "openTime": "07:00:00",
  "closeTime": "23:59:00",
  "isActive": true
}

###
# COURTS (Require a ClubId)
###

# 5. Create a new Court
# @name createCourt
POST {{Api_HostAddress}}/api/courts
Content-Type: application/json

{
  "clubId": "{{ClubId}}",
  "name": "Cancha 1 - Panorámica",
  "surfaceType": "Sintético",
  "isCovered": true,
  "layoutPositionX": 10.5,
  "layoutPositionY": 20.0,
  "layoutRotationZ": 0.0
}

###

# 6. Get all Courts
GET {{Api_HostAddress}}/api/courts

###

@CourtId = {{createCourt.response.body.id}}

# 7. Get a single Court
GET {{Api_HostAddress}}/api/courts/{{CourtId}}

###

# 8. Update a Court
PUT {{Api_HostAddress}}/api/courts/{{CourtId}}
Content-Type: application/json

{
  "name": "Cancha 1 - Panorámica Premium",
  "surfaceType": "Sintético Azul",
  "isCovered": true,
  "layoutPositionX": 10.5,
  "layoutPositionY": 20.0,
  "layoutRotationZ": 90.0,
  "isActive": true
}

###
# FIXED RESERVATIONS
###

# 9. Create a Fixed Reservation
# @name createFixedRes
POST {{Api_HostAddress}}/api/fixed-reservations
Content-Type: application/json

{
  "courtId": "{{CourtId}}",
  "customerName": "Juan Perez",
  "customerPhone": "555-1234",
  "dayOfWeek": 3,
  "startTime": "18:00:00",
  "endTime": "19:30:00",
  "startDate": "2024-06-01"
}

###

# 10. Get all Fixed Reservations
GET {{Api_HostAddress}}/api/fixed-reservations

###

@FixedResId = {{createFixedRes.response.body.id}}

# 11. Get a single Fixed Reservation
GET {{Api_HostAddress}}/api/fixed-reservations/{{FixedResId}}

###

# 12. Update a Fixed Reservation
PUT {{Api_HostAddress}}/api/fixed-reservations/{{FixedResId}}
Content-Type: application/json

{
  "customerName": "Juan Perez (Updated)",
  "customerPhone": "555-4321",
  "dayOfWeek": 3,
  "startTime": "18:00:00",
  "endTime": "19:30:00",
  "startDate": "2024-06-01",
  "endDate": "2024-12-31",
  "isActive": true
}

###
# RESERVATIONS
###

# 13. Create a Reservation
# @name createRes
POST {{Api_HostAddress}}/api/reservations
Content-Type: application/json

{
  "courtId": "{{CourtId}}",
  "fixedReservationId": "{{FixedResId}}",
  "customerName": "Maria Garcia",
  "customerPhone": "555-9876",
  "reservationDate": "2024-06-05",
  "startTime": "18:00:00",
  "endTime": "19:30:00",
  "totalAmount": 15000.00,
  "depositAmount": 5000.00,
  "isDepositPaid": true,
  "paymentMethod": "MercadoPago",
  "status": "Confirmed"
}

###

# 14. Get all Reservations
GET {{Api_HostAddress}}/api/reservations

### 

@ResId = {{createRes.response.body.id}}

# 15. Get a single Reservation
GET {{Api_HostAddress}}/api/reservations/{{ResId}}

###

# 16. Update a Reservation
PUT {{Api_HostAddress}}/api/reservations/{{ResId}}
Content-Type: application/json

{
  "customerName": "Maria Garcia",
  "customerPhone": "555-9876",
  "reservationDate": "2024-06-05",
  "startTime": "18:00:00",
  "endTime": "19:30:00",
  "totalAmount": 15000.00,
  "depositAmount": 15000.00,
  "isDepositPaid": true,
  "paymentMethod": "MercadoPago",
  "status": "Confirmed"
}

###
# DELETES (Run from bottom up to avoid foreign key constraints)
###

# 17. Delete a Reservation
DELETE {{Api_HostAddress}}/api/reservations/{{ResId}}

###

# 18. Delete a Fixed Reservation
DELETE {{Api_HostAddress}}/api/fixed-reservations/{{FixedResId}}

###

# 19. Delete a Court
DELETE {{Api_HostAddress}}/api/courts/{{CourtId}}

###

# 20. Delete a Club
DELETE {{Api_HostAddress}}/api/clubs/{{ClubId}}
